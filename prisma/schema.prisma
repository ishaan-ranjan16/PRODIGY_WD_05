generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FavoriteLocation {
  id        String   @id @default(cuid())
  cityName  String
  country   String
  lat       Float
  lon       Float
  createdAt DateTime @default(now())

  @@unique([lat, lon])
  @@map("favorite_locations")
}

model SearchHistory {
  id        String   @id @default(cuid())
  cityName  String
  country   String
  lat       Float
  lon       Float
  searchedAt DateTime @default(now())

  @@map("search_history")
}
